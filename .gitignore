# ==========================================
# Enterprise GitIgnore for Node.js Monorepo
# (Next.js + Express + Prisma + Docker)
# ==========================================

# --- Dependency Directories ---
node_modules/
jspm_packages/
web_modules/
.npm/
.yarn/
.pnpm/

# --- Environment Variables and Secrets (CRITICAL) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
.env*
!.env.example

# --- Next.js Build and Cache Outputs ---
.next/
out/
.docusaurus/

# --- Build and Dist Outputs ---
dist/
build/
bin/
obj/
out-tsc/
*.tsbuildinfo

# --- Prisma and Database ---
/prisma/generated/
/apps/backend/prisma/generated/
*.db
*.db-journal

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Diagnostic / Coverage Reports ---
coverage/
.nyc_output/

# --- OS & IDE Junk Files ---
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Docker & Temp Files ---
.docker/
.temp/
.tmp/
