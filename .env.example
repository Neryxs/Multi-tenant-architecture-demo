# =========================================================================
# CONFIGURACIÓN DE ENTORNOS - MULTI-TENANT ARCHITECTURE DEMO
# Copie este archivo como '.env' en la raíz o en los paquetes correspondientes.
# =========================================================================

# --- CONFIGURACIÓN BACKEND ---
# URL de conexión para la base de datos PostgreSQL (Multitenancy)
# Reemplace 'your_db_user', 'your_db_password', 'localhost:5432' y 'your_db_name' según corresponda
DATABASE_URL="postgresql://your_db_user:your_db_password@localhost:5432/your_db_name?schema=public"

# URL para el cliente de Redis (Caché, Rate Limiter)
REDIS_URL="redis://localhost:6379"

# Clave secreta para firmar tokens JWT (Use una clave segura de alta entropía en producción)
JWT_SECRET="your_jwt_high_entropy_secret_key"

# Puerto de escucha del servidor Express
PORT=4000
NODE_ENV="development"

# --- CONFIGURACIÓN FRONTEND (Next.js) ---
# URL de la API pública del backend
NEXT_PUBLIC_API_URL="http://localhost:4000"
